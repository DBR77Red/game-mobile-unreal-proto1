###############################################################################
# SOURCE CODE — explicit text handling + line endings
#
# Ensures consistent line endings across platforms for text source files.
###############################################################################

# C / C++ (UE source, plugins)
*.c         text eol=lf
*.cpp       text eol=lf
*.h         text eol=lf
*.hpp       text eol=lf
*.inl       text eol=lf

# C# (VS / UnrealBuildTool)
*.cs        text eol=lf diff=csharp

# Config / data
*.ini       text eol=lf
*.cfg       text eol=lf
*.json      text eol=lf
*.xml       text eol=lf
*.yaml      text eol=lf
*.yml       text eol=lf
*.toml      text eol=lf
*.md        text eol=lf
*.txt       text eol=lf

# Shell / scripts
*.sh        text eol=lf
*.bat       text eol=crlf
*.cmd       text eol=crlf
*.ps1       text eol=crlf